# Required Jules API Token
JULES_API_TOKEN="your_jules_api_token_here"

# Optional configurations
# Database path for the jules-daemon. Default is ~/.jules-daemon/jules-daemon.sqlite
# JULES_DB_PATH="~/.jules-daemon/jules-daemon.sqlite"

# Polling interval in milliseconds for SessionMonitor. Default is 45000 (45s)
# JULES_POLL_INTERVAL_MS=45000

# Parallelism cap. Max number of tasks running concurrently. Default is 5.
# JULES_PARALLELISM_CAP=5

# Stuck threshold in milliseconds. Timeout for a session before it is considered stuck. Default is 15 minutes.
# JULES_STUCK_THRESHOLD_MS=900000
